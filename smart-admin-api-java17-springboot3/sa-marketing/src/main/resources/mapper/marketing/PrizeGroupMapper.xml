<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.marketing.prize.group.dao.PrizeGroupDao">

    <resultMap id="PrizeGroupVO" type="net.lab1024.sa.marketing.prize.group.domain.vo.PrizeGroupVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="group_code" property="groupCode" />
            <result column="group_name" property="groupName" />
            <result column="description" property="description" />
            <result column="status" property="status" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                group_code, 
                group_name, 
                description, 
                status, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.groupName != null">
                            AND group_name = #{queryForm.groupName}
                        </if>
                        <if test="queryForm.status != null">
                            AND status = #{queryForm.status}
                        </if>
                        <if test="queryForm.groupCode != null">
                            AND group_code = #{queryForm.groupCode}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="PrizeGroupVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_group
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PrizeGroupVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_group
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_prize_group
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_prize_group
                        where id = #{id}
                </delete>

</mapper>