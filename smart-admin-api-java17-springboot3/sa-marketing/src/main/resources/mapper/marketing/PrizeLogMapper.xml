<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.marketing.prize.log.dao.PrizeLogDao">

    <resultMap id="PrizeLogVO" type="net.lab1024.sa.marketing.prize.log.domain.vo.PrizeLogVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="proposal_id" property="proposalId" />
            <result column="member_name" property="memberName" />
            <result column="prize_group_id" property="prizeGroupId" />
            <result column="prize_config_id" property="prizeConfigId" />
            <result column="promotion_config_id" property="promotionConfigId" />
            <result column="prize_level" property="prizeLevel" />
            <result column="prize_name" property="prizeName" />
            <result column="prize_type" property="prizeType" />
            <result column="prize_value" property="prizeValue" />
            <result column="status" property="status" />
            <result column="external_biz_no" property="externalBizNo" />
            <result column="remark" property="remark" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                proposal_id, 
                member_name, 
                prize_group_id, 
                prize_config_id, 
                promotion_config_id, 
                prize_level, 
                prize_name, 
                prize_type, 
                prize_value, 
                status, 
                external_biz_no, 
                remark, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.proposalId != null">
                            AND proposal_id = #{queryForm.proposalId}
                        </if>
                        <if test="queryForm.memberName != null">
                            AND member_name = #{queryForm.memberName}
                        </if>
                        <if test="queryForm.prizeLevel != null">
                            AND prize_level = #{queryForm.prizeLevel}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="PrizeLogVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_log
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PrizeLogVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_log
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_prize_log
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_prize_log
                        where id = #{id}
                </delete>

</mapper>