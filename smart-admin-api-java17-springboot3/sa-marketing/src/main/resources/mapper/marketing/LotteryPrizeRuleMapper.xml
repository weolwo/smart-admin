<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.lottery.prizerule.dao.LotteryPrizeRuleDao">

    <resultMap id="LotteryPrizeRuleVO" type="net.lab1024.sa.lottery.prizerule.domain.vo.LotteryPrizeRuleVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="lottery_code" property="lotteryCode" />
            <result column="prize_level" property="prizeLevel" />
            <result column="prize_name" property="prizeName" />
            <result column="win_count" property="winCount" />
            <result column="prize_code" property="prizeCode" />
            <result column="prize_value" property="prizeValue" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                lottery_code, 
                prize_level, 
                prize_name, 
                win_count, 
                prize_code, 
                prize_value, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.tenantId != null">
                            AND tenant_id = #{queryForm.tenantId}
                        </if>
                        <if test="queryForm.lotteryCode != null">
                            AND lottery_code = #{queryForm.lotteryCode}
                        </if>
                        <if test="queryForm.prizeLevel != null">
                            AND prize_level = #{queryForm.prizeLevel}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="LotteryPrizeRuleVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_lottery_prize_rule
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="LotteryPrizeRuleVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_lottery_prize_rule
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_lottery_prize_rule
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_lottery_prize_rule
                        where id = #{id}
                </delete>

</mapper>