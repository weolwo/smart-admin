<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.marketing.ledger.transaction.dao.MemberAssetTransactionDao">

    <resultMap id="MemberAssetTransactionVO" type="net.lab1024.sa.marketing.ledger.transaction.domain.vo.MemberAssetTransactionVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="member_name" property="memberName" />
            <result column="asset_type" property="assetType" />
            <result column="transaction_type" property="transactionType" />
            <result column="change_amount" property="changeAmount" />
            <result column="balance_after" property="balanceAfter" />
            <result column="biz_type" property="bizType" />
            <result column="biz_ref_id" property="bizRefId" />
            <result column="remark" property="remark" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                member_name, 
                asset_type, 
                transaction_type, 
                change_amount, 
                balance_after, 
                biz_type, 
                biz_ref_id, 
                remark, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.memberName != null">
                            AND member_name = #{queryForm.memberName}
                        </if>
                        <if test="queryForm.assetType != null">
                            AND asset_type = #{queryForm.assetType}
                        </if>
                        <if test="queryForm.bizType != null">
                            AND biz_type = #{queryForm.bizType}
                        </if>
                        <if test="queryForm.bizRefId != null">
                            AND biz_ref_id = #{queryForm.bizRefId}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="MemberAssetTransactionVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_member_asset_transaction
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="MemberAssetTransactionVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_member_asset_transaction
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_member_asset_transaction
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_member_asset_transaction
                        where id = #{id}
                </delete>

</mapper>