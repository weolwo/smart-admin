<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.lottery.issue.dao.LotteryIssueDao">

    <resultMap id="LotteryIssueVO" type="net.lab1024.sa.lottery.issue.domain.vo.LotteryIssueVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="lottery_code" property="lotteryCode" />
            <result column="issue_no" property="issueNo" />
            <result column="sold_count" property="soldCount" />
            <result column="sell_start_time" property="sellStartTime" />
            <result column="sell_end_time" property="sellEndTime" />
            <result column="open_time" property="openTime" />
            <result column="can_repeat" property="canRepeat" />
            <result column="winning_number" property="winningNumber" />
            <result column="status" property="status" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                lottery_code, 
                issue_no, 
                sold_count, 
                sell_start_time, 
                sell_end_time, 
                open_time, 
                can_repeat, 
                winning_number, 
                status, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.tenantId != null">
                            AND tenant_id = #{queryForm.tenantId}
                        </if>
                        <if test="queryForm.lotteryCode != null">
                            AND lottery_code = #{queryForm.lotteryCode}
                        </if>
                        <if test="queryForm.issueNo != null">
                            AND issue_no = #{queryForm.issueNo}
                        </if>
                        <if test="queryForm.status != null">
                            AND status = #{queryForm.status}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="LotteryIssueVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_lottery_issue
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="LotteryIssueVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_lottery_issue
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_lottery_issue
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_lottery_issue
                        where id = #{id}
                </delete>

</mapper>