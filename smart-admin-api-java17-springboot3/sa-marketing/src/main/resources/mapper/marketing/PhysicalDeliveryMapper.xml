<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.marketing.ledger.physical.dao.PhysicalDeliveryDao">

    <resultMap id="PhysicalDeliveryVO" type="net.lab1024.sa.marketing.ledger.physical.domain.vo.PhysicalDeliveryVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="member_name" property="memberName" />
            <result column="proposal_id" property="proposalId" />
            <result column="prize_config_id" property="prizeConfigId" />
            <result column="receiver_name" property="receiverName" />
            <result column="receiver_phone" property="receiverPhone" />
            <result column="receiver_address" property="receiverAddress" />
            <result column="logistics_company" property="logisticsCompany" />
            <result column="logistics_no" property="logisticsNo" />
            <result column="status" property="status" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                member_name, 
                proposal_id, 
                prize_config_id, 
                receiver_name, 
                receiver_phone, 
                receiver_address, 
                logistics_company, 
                logistics_no, 
                status, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.memberName != null">
                            AND member_name = #{queryForm.memberName}
                        </if>
                        <if test="queryForm.proposalId != null">
                            AND proposal_id = #{queryForm.proposalId}
                        </if>
                        <if test="queryForm.status != null">
                            AND status = #{queryForm.status}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
                        <if test="queryForm.logisticsNo != null">
                            AND logistics_no = #{queryForm.logisticsNo}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="PhysicalDeliveryVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_physical_delivery
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PhysicalDeliveryVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_physical_delivery
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_physical_delivery
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_physical_delivery
                        where id = #{id}
                </delete>

</mapper>