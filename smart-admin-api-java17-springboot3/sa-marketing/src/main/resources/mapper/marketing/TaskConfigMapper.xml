<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.marketing.task.config.dao.TaskConfigDao">

    <resultMap id="TaskConfigVO" type="net.lab1024.sa.marketing.task.config.domain.vo.TaskConfigVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="task_name" property="taskName" />
            <result column="template_code" property="templateCode" />
            <result column="trigger_event" property="triggerEvent" />
            <result column="task_group" property="taskGroup" />
            <result column="target_audience" property="targetAudience" />
            <result column="limit_type" property="limitType" />
            <result column="limit_count" property="limitCount" />
            <result column="rule_config" property="ruleConfig" />
            <result column="sort_weight" property="sortWeight" />
            <result column="action_url" property="actionUrl" />
            <result column="ui_config" property="uiConfig" />
            <result column="status" property="status" />
            <result column="start_time" property="startTime" />
            <result column="end_time" property="endTime" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                task_name, 
                template_code, 
                trigger_event, 
                task_group, 
                target_audience, 
                limit_type, 
                limit_count, 
                rule_config, 
                sort_weight, 
                action_url, 
                ui_config, 
                status, 
                start_time, 
                end_time, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.taskName != null">
                            AND task_name = #{queryForm.taskName}
                        </if>
                        <if test="queryForm.templateCode != null">
                            AND template_code = #{queryForm.templateCode}
                        </if>
                        <if test="queryForm.taskGroup != null">
                            AND task_group = #{queryForm.taskGroup}
                        </if>
                        <if test="queryForm.targetAudience != null">
                            AND target_audience = #{queryForm.targetAudience}
                        </if>
                        <if test="queryForm.startTimeBegin != null">
                            AND start_time &gt;= #{queryForm.startTimeBegin}
                        </if>
                        <if test="queryForm.startTimeEnd != null">
                            AND start_time &lt;= #{queryForm.startTimeEnd}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="TaskConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_task_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="TaskConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_task_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_task_config
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_task_config
                        where id = #{id}
                </delete>

</mapper>