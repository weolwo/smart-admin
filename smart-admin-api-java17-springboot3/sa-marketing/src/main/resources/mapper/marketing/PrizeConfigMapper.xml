<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.prize.prizeconfig.dao.PrizeConfigDao">

    <resultMap id="PrizeConfigVO" type="net.lab1024.sa.prize.prizeconfig.domain.vo.PrizeConfigVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="activity_code" property="activityCode" />
            <result column="promotion_config_id" property="promotionConfigId" />
            <result column="prize_type" property="prizeType" />
            <result column="prize_name" property="prizeName" />
            <result column="prize_code" property="prizeCode" />
            <result column="prize_level" property="prizeLevel" />
            <result column="prize_value" property="prizeValue" />
            <result column="sort_weight" property="sortWeight" />
            <result column="ext" property="ext" />
            <result column="status" property="status" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                activity_code, 
                promotion_config_id, 
                prize_type, 
                prize_name, 
                prize_code, 
                prize_level, 
                prize_value, 
                sort_weight, 
                ext, 
                status, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.tenantId != null">
                            AND tenant_id = #{queryForm.tenantId}
                        </if>
                        <if test="queryForm.activityCode != null">
                            AND activity_code = #{queryForm.activityCode}
                        </if>
                        <if test="queryForm.prizeCode != null">
                            AND prize_code = #{queryForm.prizeCode}
                        </if>
                        <if test="queryForm.prizeLevel != null">
                            AND prize_level = #{queryForm.prizeLevel}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="PrizeConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PrizeConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_prize_config
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_prize_config
                        where id = #{id}
                </delete>

</mapper>