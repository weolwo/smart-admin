<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.marketing.prize.config.dao.PrizeConfigDao">

    <resultMap id="PrizeConfigVO" type="net.lab1024.sa.marketing.prize.config.domain.vo.PrizeConfigVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="prize_group_id" property="prizeGroupId" />
            <result column="promotion_config_id" property="promotionConfigId" />
            <result column="prize_type" property="prizeType" />
            <result column="prize_name" property="prizeName" />
            <result column="grant_mode" property="grantMode" />
            <result column="prize_level" property="prizeLevel" />
            <result column="prize_amount_min" property="prizeAmountMin" />
            <result column="prize_amount_max" property="prizeAmountMax" />
            <result column="probability" property="probability" />
            <result column="sort_weight" property="sortWeight" />
            <result column="status" property="status" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                prize_group_id, 
                promotion_config_id, 
                prize_type, 
                prize_name, 
                grant_mode, 
                prize_level, 
                prize_amount_min, 
                prize_amount_max, 
                probability, 
                sort_weight, 
                status, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.prizeGroupId != null">
                            AND prize_group_id = #{queryForm.prizeGroupId}
                        </if>
                        <if test="queryForm.prizeType != null">
                            AND prize_type = #{queryForm.prizeType}
                        </if>
                        <if test="queryForm.prizeName != null">
                            AND prize_name = #{queryForm.prizeName}
                        </if>
                        <if test="queryForm.promotionConfigId != null">
                            AND promotion_config_id = #{queryForm.promotionConfigId}
                        </if>
                        <if test="queryForm.prizeLevel != null">
                            AND prize_level = #{queryForm.prizeLevel}
                        </if>
                        <if test="queryForm.status != null">
                            AND status = #{queryForm.status}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="PrizeConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PrizeConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_prize_config
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_prize_config
                        where id = #{id}
                </delete>

</mapper>