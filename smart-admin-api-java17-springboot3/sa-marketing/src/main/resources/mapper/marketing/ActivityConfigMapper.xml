<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.activity.dao.ActivityConfigDao">

    <resultMap id="ActivityConfigVO" type="net.lab1024.sa.activity.domain.vo.ActivityConfigVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="activity_code" property="activityCode" />
            <result column="activity_name" property="activityName" />
            <result column="activity_type" property="activityType" />
            <result column="status" property="status" />
            <result column="start_time" property="startTime" />
            <result column="end_time" property="endTime" />
            <result column="script_id" property="scriptId" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                activity_code, 
                activity_name, 
                activity_type, 
                status, 
                start_time, 
                end_time, 
                script_id, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.tenantId != null">
                            AND tenant_id = #{queryForm.tenantId}
                        </if>
                        <if test="queryForm.activityCode != null">
                            AND activity_code = #{queryForm.activityCode}
                        </if>
                        <if test="queryForm.activityName != null">
                            AND activity_name = #{queryForm.activityName}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="ActivityConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_activity_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="ActivityConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_activity_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_activity_config
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_activity_config
                        where id = #{id}
                </delete>

</mapper>