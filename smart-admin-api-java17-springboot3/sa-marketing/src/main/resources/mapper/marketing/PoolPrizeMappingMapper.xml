    <sql id="base_columns">
                id, 
                tenant_id, 
                pool_code, 
                prize_item_id, 
                probability, 
                sort_weight, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
        </where>
    </sql>

    <select id="queryPage" resultMap="PoolPrizeMappingVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_pool_prize_mapping
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PoolPrizeMappingVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_pool_prize_mapping
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_pool_prize_mapping
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_pool_prize_mapping
                        where id = #{id}
                </delete>

</mapper>