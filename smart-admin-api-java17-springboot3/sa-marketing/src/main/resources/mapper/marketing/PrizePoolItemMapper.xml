<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.draw.poolitem.dao.PrizePoolItemDao">

    <resultMap id="PrizePoolItemVO" type="net.lab1024.sa.draw.poolitem.domain.vo.PrizePoolItemVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="activity_code" property="activityCode" />
            <result column="item_name" property="itemName" />
            <result column="item_value" property="itemValue" />
            <result column="item_image" property="itemImage" />
            <result column="prize_code" property="prizeCode" />
            <result column="user_max_count" property="userMaxCount" />
            <result column="total_stock" property="totalStock" />
            <result column="used_stock" property="usedStock" />
            <result column="white_list" property="whiteList" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                activity_code, 
                item_name, 
                item_value, 
                item_image, 
                prize_code, 
                user_max_count, 
                total_stock, 
                used_stock, 
                white_list, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.tenantId != null">
                            AND tenant_id = #{queryForm.tenantId}
                        </if>
                        <if test="queryForm.activityCode != null">
                            AND activity_code = #{queryForm.activityCode}
                        </if>
                        <if test="queryForm.itemName != null">
                            AND item_name = #{queryForm.itemName}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="PrizePoolItemVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_pool_item
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PrizePoolItemVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_prize_pool_item
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_prize_pool_item
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_prize_pool_item
                        where id = #{id}
                </delete>

</mapper>