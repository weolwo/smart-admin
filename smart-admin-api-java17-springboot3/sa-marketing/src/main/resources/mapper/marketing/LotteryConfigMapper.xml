<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.lottery.config.dao.LotteryConfigDao">

    <resultMap id="LotteryConfigVO" type="net.lab1024.sa.lottery.config.domain.vo.LotteryConfigVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="activity_code" property="activityCode" />
            <result column="lottery_code" property="lotteryCode" />
            <result column="lottery_name" property="lotteryName" />
            <result column="number_charset" property="numberCharset" />
            <result column="number_length" property="numberLength" />
            <result column="total_count" property="totalCount" />
            <result column="cost_asset_type" property="costAssetType" />
            <result column="cost_value" property="costValue" />
            <result column="status" property="status" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                activity_code, 
                lottery_code, 
                lottery_name, 
                number_charset, 
                number_length, 
                total_count, 
                cost_asset_type, 
                cost_value, 
                status, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.tenantId != null">
                            AND tenant_id = #{queryForm.tenantId}
                        </if>
                        <if test="queryForm.activityCode != null">
                            AND activity_code = #{queryForm.activityCode}
                        </if>
                        <if test="queryForm.lotteryCode != null">
                            AND lottery_code = #{queryForm.lotteryCode}
                        </if>
                        <if test="queryForm.lotteryName != null">
                            AND lottery_name = #{queryForm.lotteryName}
                        </if>
                        <if test="queryForm.status != null">
                            AND status = #{queryForm.status}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="LotteryConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_lottery_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="LotteryConfigVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_lottery_config
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_lottery_config
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_lottery_config
                        where id = #{id}
                </delete>

</mapper>