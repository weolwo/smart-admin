<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="net.lab1024.sa.marketing.riskmanager.proposal.dao.PromotionProposalDao">

    <resultMap id="PromotionProposalVO" type="net.lab1024.sa.marketing.riskmanager.proposal.domain.vo.PromotionProposalVO">
            <result column="id" property="id" />
            <result column="tenant_id" property="tenantId" />
            <result column="member_name" property="memberName" />
            <result column="task_record_id" property="taskRecordId" />
            <result column="promotion_config_id" property="promotionConfigId" />
            <result column="status" property="status" />
            <result column="stage_level" property="stageLevel" />
            <result column="remark" property="remark" />
            <result column="first_reviewer" property="firstReviewer" />
            <result column="first_review_time" property="firstReviewTime" />
            <result column="second_reviewer" property="secondReviewer" />
            <result column="second_review_time" property="secondReviewTime" />
            <result column="review_comment" property="reviewComment" />
            <result column="create_by" property="createBy" />
            <result column="create_time" property="createTime" />
            <result column="update_by" property="updateBy" />
            <result column="update_time" property="updateTime" />
    </resultMap>

    <sql id="base_columns">
                id, 
                tenant_id, 
                member_name, 
                task_record_id, 
                promotion_config_id, 
                status, 
                stage_level, 
                remark, 
                first_reviewer, 
                first_review_time, 
                second_reviewer, 
                second_review_time, 
                review_comment, 
                create_by, 
                create_time, 
                update_by, 
                update_time
    </sql>

    <sql id="query_conditions">
        <where>
                        <if test="queryForm.memberName != null">
                            AND member_name = #{queryForm.memberName}
                        </if>
                        <if test="queryForm.createTimeBegin != null">
                            AND create_time &gt;= #{queryForm.createTimeBegin}
                        </if>
                        <if test="queryForm.createTimeEnd != null">
                            AND create_time &lt;= #{queryForm.createTimeEnd}
                        </if>
                        <if test="queryForm.taskRecordId != null">
                            AND task_record_id = #{queryForm.taskRecordId}
                        </if>
                        <if test="queryForm.status != null">
                            AND status = #{queryForm.status}
                        </if>
                        <if test="queryForm.promotionConfigId != null">
                            AND promotion_config_id = #{queryForm.promotionConfigId}
                        </if>
        </where>
    </sql>

    <select id="queryPage" resultMap="PromotionProposalVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_promotion_proposal
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

    <select id="queryList" resultMap="PromotionProposalVO">
        SELECT
        <include refid="base_columns"/>
        FROM t_promotion_proposal
        <include refid="query_conditions"/>
        ORDER BY create_time DESC
    </select>

                <delete id="batchDelete">
                    delete from t_promotion_proposal
                    where id in
                    <foreach collection="idList" open="(" close=")" separator="," item="item">
                        #{item}
                    </foreach>
                </delete>
                <delete id="deleteById">
                    delete from t_promotion_proposal
                        where id = #{id}
                </delete>

</mapper>